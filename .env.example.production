# =====================================================================
# .env.example.production
# ---------------------------------------------------------------------
# Template for production secrets. Copy this file to `.env.production`
# (which Docker Compose reads for every service) and fill each value.
#
# NEVER commit `.env.production` to git — `.gitignore` already excludes
# every `.env*` file.
#
# Quickest path: run `./deploy.sh` on a fresh server. It will generate
# a random `.env.production` for you. Use this template only when you
# need to provision secrets manually (e.g. CI/CD, image registry, or
# restoring an existing deployment).
# =====================================================================

# ---------------------------------------------------------------------
# PostgreSQL connection
# ---------------------------------------------------------------------
# Provide EITHER `DATABASE_URL` (recommended for managed/external Postgres)
# OR the four component variables (DB_HOST/DB_USER/DB_PASSWORD/DB_NAME)
# consumed by `lib/database-url.ts` — the app builds the URL automatically
# when DATABASE_URL is not set.
#
# DATABASE_URL example:
#   DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/dccheck
# Leave commented out if you use the component form below.
# DATABASE_URL=

# Hostname of the PostgreSQL service as reachable from the app containers.
# When using the bundled `docker compose up`, this should be `db`.
DB_HOST=

# PostgreSQL port. Use 5432 unless you have remapped it on the host.
DB_PORT=

# PostgreSQL role that owns the application schema. Must match
# POSTGRES_USER passed to the db container on first boot, otherwise
# the database will refuse to authenticate the app.
#
# Generate with: openssl rand -hex 8   (or any short identifier you like)
DB_USER=

# Password for the PostgreSQL role. Must be at least 16 characters in
# production; the included deploy.sh uses 24 random bytes.
#
# Generate with: openssl rand -base64 24
DB_PASSWORD=

# Database name (created on first boot by the db container).
# Must match POSTGRES_DB. Default in this repo is `dccheck`.
DB_NAME=dccheck

# ---------------------------------------------------------------------
# Session signing
# ---------------------------------------------------------------------

# Secret used by `jose` to sign JWT session cookies. Must be at least
# 32 characters; the app refuses to start in production if this is
# missing or still set to the development default.
#
# Generate with: openssl rand -base64 32
SESSION_SECRET=

# ---------------------------------------------------------------------
# Cookie hardening
# ---------------------------------------------------------------------

# Set to `true` when serving the app over HTTPS (recommended in
# production behind a reverse proxy). When `false`, the session cookie
# is set without the `Secure` flag so plain-HTTP local testing works.
# The app reads this value verbatim from `process.env.SECURE_COOKIES`.
SECURE_COOKIES=true

# ---------------------------------------------------------------------
# Optional: S3 (only required if you are not storing uploads locally)
# ---------------------------------------------------------------------

# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=
# S3_BUCKET_NAME=

# ---------------------------------------------------------------------
# AI provider key encryption (N49)
# ---------------------------------------------------------------------
# Encrypts the `siem_settings.ai_api_key` column at rest with AES-256-GCM
# so a database dump (e.g. via /api/admin/backup or direct SQL access)
# does not leak the provider API key. REQUIRED in production: the app
# refuses to boot in production when this is missing or still equal to
# the development default. Existing plaintext rows can be re-encrypted
# on demand with: npx tsx scripts/encrypt-existing-ai-keys.ts
#
# Generate with: openssl rand -base64 32
AI_KEY_ENCRYPTION_SECRET=
